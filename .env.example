# Copy to .env and fill in. Never commit the real .env.

# --- Database (Neon Postgres connection string) ---
DATABASE_URL=postgresql://user:password@host/dbname

# --- Security ---
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ENVIRONMENT=development

# --- CORS (comma-separated origins, or * for all) ---
CORS_ORIGINS=*

# --- football-data.org (free tier, FIFA World Cup 2026, competition id 2000) ---
# Get a free key at https://www.football-data.org/client/register
FOOTBALL_API_KEY=
FOOTBALL_CACHE_TTL=60

# --- StatsBomb (OPTIONAL) ---
# Open data is free and needs no credentials. Set these only if you have a paid
# StatsBomb subscription for live / current-season coverage.
STATSBOMB_USERNAME=
STATSBOMB_PASSWORD=

# --- Optional third-party integrations ---
SENDGRID_API_KEY=
STRIPE_SECRET_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
